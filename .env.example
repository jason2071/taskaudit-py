# ─────────────────────────────────────────────────────────
# taskaudit — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────

# Default provider (anthropic | openai | gemini | openrouter)
TASKAUDIT_PROVIDER=anthropic

# ── API Keys (ใส่เฉพาะ provider ที่ใช้) ──
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# ── Model override (optional — ถ้าไม่ใส่จะใช้ default) ──
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# OPENAI_MODEL=gpt-4o
# GEMINI_MODEL=gemini-2.5-flash
# OPENROUTER_MODEL=anthropic/claude-sonnet-4
